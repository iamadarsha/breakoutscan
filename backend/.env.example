# Equifidy Backend — Environment Variables
# Copy to .env and fill in your values

# ── App Config ─────────────────────────────────────────────────────────────
APP_NAME=Equifidy
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database (Docker Compose default) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://breakout:breakout_dev_pass@localhost:5432/stockdb

# ── Redis (Docker Compose default) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Upstox API (get from https://developer.upstox.com/) ───────────────────
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Supabase (get from https://supabase.com/) ──────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Optional: Telegram Bot Alerts ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_if_needed

# ── Optional: SendGrid Email Alerts ───────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_if_needed
